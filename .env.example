# Database
# For Aiven or other managed PostgreSQL with self-signed certificates, add ?sslmode=require to the URL
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=""

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Provider - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Ollama Cloud API
OLLAMA_CLOUD_API_KEY=""
OLLAMA_CLOUD_MODEL="gpt-oss:120b-cloud"
# Base URL (can include /api suffix, will be normalized automatically)
OLLAMA_CLOUD_API_URL="https://cloud.ollama.ai"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
