# Database
# For Aiven or other managed PostgreSQL with self-signed certificates, add ?sslmode=require to the URL
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=""

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers - GitHub
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# OAuth Providers - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Ollama Cloud API
OLLAMA_CLOUD_API_KEY=""
OLLAMA_CLOUD_MODEL="gpt-oss:120b-cloud"
OLLAMA_CLOUD_API_URL="https://cloud.ollama.ai/api"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
