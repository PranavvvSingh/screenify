// Prisma schema for Screenify - AI-Powered Candidate Screening Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH DOMAIN (Better Auth)
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations - Only recruiters have user accounts
  accounts  Account[]
  sessions  Session[]
  recruiter Recruiter?

  @@index([email])
  @@map("users")
}

// Better Auth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Better Auth Session model
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Better Auth Verification model
model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verifications")
}

// ============================================
// APPLICATION DOMAIN
// ============================================

// Recruiter table - Users who create job roles and screen candidates
model Recruiter {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRolesCreated JobRole[] @relation("RecruiterJobRoles")

  @@index([userId])
  @@map("recruiters")
}


model JobRole {
  id             String   @id @default(cuid())
  title          String
  description    String?  @db.Text
  jd             Json // JSONB: JDRequirements - { job_title, description, requirements[], required_skills[], preferred_skills[], experience: { min_years, max_years } }
  baseQuestions  Json? // JSONB: Array of standard questions (70% of total) - reused for all candidates
  totalQuestions Int      @default(10) // Total questions (5-25), maintains 70/30 split
  recruiterId    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  recruiter Recruiter @relation("RecruiterJobRoles", fields: [recruiterId], references: [id], onDelete: Cascade)
  quizzes   Quiz[]

  @@index([recruiterId])
  @@index([title])
  @@map("job_roles")
}

// NOTE: Invitation model removed - no longer needed with new flow
// Recruiter uploads resume directly → creates candidate + quiz → gets unique link

// Quiz table - Combined standard (70%) + verification (30%) questions, fully shuffled
// Candidate info stored inline (no separate Candidate table)
model Quiz {
  id             String   @id @default(cuid())
  jobRoleId      String
  candidateName  String // Candidate's name (from resume upload)
  candidateEmail String // Candidate's email (from resume upload)
  token          String   @unique @default(cuid()) // Unique link for candidate access (no auth)
  questions      Json // JSONB: [{ id, type: 'STANDARD' | 'RESUME_VERIFICATION', question, options: [], correctAnswer, skill }]
  duration       Int      @default(20) // Duration in minutes
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  jobRole JobRole      @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
  result  QuizResult?

  @@index([jobRoleId])
  @@index([token])
  @@index([candidateEmail]) // For querying quizzes by candidate
  @@map("quizzes")
}

// QuizAnswer table - Stores each individual answer submitted in real-time
model QuizAnswer {
  id          String   @id @default(cuid())
  quizId      String
  questionId  String // Reference to question ID in Quiz.questions JSON
  answer      String // Candidate's answer: "A", "B", "C", or "D"
  isCorrect   Boolean? // Calculated when quiz is submitted
  timeTaken   Int // Seconds spent on this question
  submittedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionId]) // One answer per question per quiz
  @@index([quizId])
  @@map("quiz_answers")
}

// QuizResult table - Two-part scoring: standardScore (ranking) + verificationStatus (fraud flags)
model QuizResult {
  id          String    @id @default(cuid())
  quizId      String    @unique // One result per quiz
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  // Part 1: Standard Questions Score (70%) - Used for ranking
  standardScore   Float? // Percentage: 0-100 from standard questions only
  standardCorrect Int? // Number of correct standard answers
  standardTotal   Int? // Total standard questions

  // Part 2: Verification Status (30%) - Fraud detection (not scored)
  verificationStatus  VerificationStatus? // VERIFIED, QUESTIONABLE, or DISCREPANCY
  verificationCorrect Int? // Number of correct verification answers
  verificationTotal   Int? // Total verification questions
  verificationResults Json? // JSONB: [{ claim, question, correct }]

  // Other metrics
  skillBreakdown     Json? // JSONB: { React: 85, Node: 70 } - from standard questions only
  confidenceScore    Float? // 0-100 based on proctoring flags
  anomalyIndicators  Json? // JSONB: [{ type, severity, details }]
  status             QuizResultStatus @default(IN_PROGRESS)
  proctoringMetadata Json? // JSONB: { tabSwitches: 3, fullscreenExits: 1, events: [...] }

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([standardScore])
  @@index([verificationStatus])
  @@map("quiz_results")
}

enum VerificationStatus {
  VERIFIED // ≥80% verification questions correct
  QUESTIONABLE // 50-79% correct
  DISCREPANCY // <50% correct
}

enum QuizResultStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  EXPIRED
  ENDED // Quiz ended due to cheating detection
}
