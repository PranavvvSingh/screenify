// Prisma schema for Screenify - AI-Powered Candidate Screening Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH DOMAIN (Better Auth)
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts  Account[]
  sessions  Session[]
  recruiter Recruiter?
  candidate Candidate?

  @@index([email])
  @@map("users")
}

// Better Auth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

// Better Auth Session model
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Better Auth Verification model
model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verifications")
}

// ============================================
// APPLICATION DOMAIN
// ============================================

// Recruiter table - Users who create job roles and screen candidates
model Recruiter {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRolesCreated JobRole[] @relation("RecruiterJobRoles")

  @@index([userId])
  @@map("recruiters")
}

// Candidate table - Users who apply through invitations
model Candidate {
  id           String   @id @default(cuid())
  userId       String   @unique
  invitationId String
  resumeText   String?  @db.Text
  profile      Json?    // JSONB: { skills: [], experience: [], education: [], summary: "" }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation Invitation @relation(fields: [invitationId], references: [id])
  quizzes    Quiz[]
  attempts   Attempt[]

  @@index([userId])
  @@index([invitationId])
  @@map("candidates")
}

// JobRole table - Job positions created by recruiters
model JobRole {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  jdText       String?  @db.Text
  requirements Json?    // JSONB: { skills: [], experience: "", qualifications: [], responsibilities: [] }
  recruiterId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recruiter   Recruiter    @relation("RecruiterJobRoles", fields: [recruiterId], references: [id], onDelete: Cascade)
  invitations Invitation[]
  quizzes     Quiz[]

  @@index([recruiterId])
  @@index([createdAt])
  @@map("job_roles")
}

// Invitation table - Links for candidates to apply
model Invitation {
  id        String    @id @default(cuid())
  jobRoleId String
  token     String    @unique @default(cuid())
  expiresAt DateTime?
  maxUses   Int?      // NULL = unlimited
  usedCount Int       @default(0)
  createdAt DateTime  @default(now())

  jobRole    JobRole     @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  candidates Candidate[]

  @@index([token])
  @@index([jobRoleId])
  @@map("invitations")
}

// Quiz table - Generated at JobRole + Candidate conjunction
model Quiz {
  id          String   @id @default(cuid())
  jobRoleId   String
  candidateId String
  questions   Json     // JSONB: [{ id, question, options: [], correctAnswer, skill, difficulty }]
  duration    Int      // Duration in minutes
  createdAt   DateTime @default(now())

  jobRole   JobRole   @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  attempts  Attempt[]

  @@unique([jobRoleId, candidateId]) // One quiz per job role-candidate pair
  @@index([jobRoleId])
  @@index([candidateId])
  @@map("quizzes")
}

// Attempt table - Single quiz attempt by candidate (includes evaluation)
model Attempt {
  id              String        @id @default(cuid())
  quizId          String
  candidateId     String
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  responses       Json?         // JSONB: [{ questionId, selectedAnswer, timeTaken }]
  proctoringFlags Json?         // JSONB: { tabSwitches: 0, visibilityChanges: 0, fullscreenExits: 0, timestamps: [] }
  isComplete      Boolean       @default(false)
  status          AttemptStatus @default(IN_PROGRESS)

  // Evaluation fields (populated after submission)
  score           Float?        // Percentage score (0-100)
  evaluationData  Json?         // JSONB: { skillBreakdown: {...}, confidenceScore: 0-100, anomalies: {...}, etc. }
  evaluatedAt     DateTime?

  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([quizId, candidateId]) // Single attempt enforcement
  @@index([quizId])
  @@index([candidateId])
  @@index([status])
  @@index([score])
  @@map("attempts")
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  EXPIRED
}
